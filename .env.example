# Copia a `.env.local` y rellena los valores.

# Sanity (crea un proyecto en https://www.sanity.io/manage)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# URL pública del sitio (producción: https://redshell.cloud — local: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase (misma estructura que el blog de referencia: auth + comentarios + newsletter)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash (rate limit del boletín)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Opcional: Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Opcional: Google Search Console (verificación por meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Opcional: AdSense (cliente ca-pub-… y slots por unidad)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_DEFAULT=
NEXT_PUBLIC_ADSENSE_SLOT_IN_ARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_MID=
